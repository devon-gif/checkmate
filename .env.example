# ─────────────────────────────────────────────────────────────────────────────
# CheckRay environment variables
#
# Copy to `.env.local` and fill in. Every variable below is read somewhere in
# the codebase (verified against `process.env.*` usage). NEXT_PUBLIC_* values
# are exposed to the browser — never put secrets behind that prefix.
# ─────────────────────────────────────────────────────────────────────────────

# ── App URLs ────────────────────────────────────────────────────────────────
# Canonical app URL (no trailing slash). Used for Stripe redirect URLs.
NEXT_PUBLIC_APP_URL=https://checkray.app
# Public site URL (used for absolute links / metadata). Often the same value.
NEXT_PUBLIC_SITE_URL=https://checkray.app

# ── Supabase ──────────────────────────────────────────────────────────────────
# Client-safe (NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side ONLY. NEVER add NEXT_PUBLIC_ prefix. Never log or expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI risk analyzer (server-side only) ───────────────────────────────────────
OPENAI_API_KEY=sk-...
CHECKMATE_ANALYZER_MODEL=gpt-4o-mini

# ── Email: Resend (server-side only) ──────────────────────────────────────────
# Outbound + inbound (ray@inbound.checkray.app). See docs/INBOUND_EMAIL_SETUP.md.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ray@checkray.app
# Inbound webhook signing secret + the inbound address it routes to.
RESEND_INBOUND_WEBHOOK_SECRET=whsec_...
INBOUND_EMAIL_ADDRESS=ray@inbound.checkray.app

# ── Admin tools (server-side only, never NEXT_PUBLIC_) ────────────────────────
# Comma-separated list of admin emails.
ADMIN_EMAILS=you@example.com
# Set to "true" to enable admin-only tooling.
ENABLE_ADMIN_TOOLS=false
# Optional: where admin login redirects after auth.
# ADMIN_LOGIN_REDIRECT=/admin

# ── Feedback signing (server-side only) ───────────────────────────────────────
FEEDBACK_SIGNING_SECRET=

# ── Stripe billing (server-side secrets; leave blank until billing is live) ───
# See BILLING_TODO.md for full setup steps.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Per-plan price IDs (server-side; no NEXT_PUBLIC_ prefix).
STRIPE_BASIC_MONTHLY_PRICE_ID=
STRIPE_BASIC_YEARLY_PRICE_ID=
STRIPE_PLUS_MONTHLY_PRICE_ID=
STRIPE_PLUS_YEARLY_PRICE_ID=
STRIPE_FAMILY_MONTHLY_PRICE_ID=
STRIPE_FAMILY_YEARLY_PRICE_ID=

# DEPRECATED — legacy single price ID. Kept only as a fallback for
# `basic_monthly` so older deployments keep working. Prefer the per-plan
# STRIPE_*_PRICE_ID vars above and remove this once migrated.
# The other legacy NEXT_PUBLIC_STRIPE_PRICE_ID_{BASIC,BASIC_YEARLY,PLUS,
# PLUS_YEARLY} names are no longer read by the code and have been removed.
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO=

# ── Optional: GitHub OAuth (set NEXT_PUBLIC_AUTH_GITHUB=true to enable) ────────
NEXT_PUBLIC_AUTH_GITHUB=false
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Optional: production hero phone video hosted on Vercel Blob ────────────────
# Local public/videos/*.mp4 files are fallback/testing only.
NEXT_PUBLIC_CHECKRAY_PHONE_VIDEO_URL=

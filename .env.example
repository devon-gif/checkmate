# Required for Supabase (safe to expose client-side — NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required: server-side only. NEVER add NEXT_PUBLIC_ prefix. Never log or expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for AI risk analysis (server-side only)
OPENAI_API_KEY=sk-...
CHECKMATE_ANALYZER_MODEL=gpt-4o-mini

# Required: canonical app URL (no trailing slash). Used in Stripe redirect URLs.
NEXT_PUBLIC_APP_URL=https://checkray.app

# Optional: GitHub OAuth (set NEXT_PUBLIC_AUTH_GITHUB=false to disable)
NEXT_PUBLIC_AUTH_GITHUB=false
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional: Stripe billing. Leave blank until billing is live.
# See BILLING_TODO.md for full setup steps.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID_BASIC=
NEXT_PUBLIC_STRIPE_PRICE_ID_BASIC_YEARLY=
NEXT_PUBLIC_STRIPE_PRICE_ID_PLUS=
NEXT_PUBLIC_STRIPE_PRICE_ID_PLUS_YEARLY=
# Legacy single price ID (current checkout session route uses this)
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO=

# Optional: production hero phone video hosted on Vercel Blob.
# Local public/videos/*.mp4 files are fallback/testing only.
NEXT_PUBLIC_CHECKRAY_PHONE_VIDEO_URL=

# Admin access — comma-separated list of admin emails (server-only, never NEXT_PUBLIC_)
# ADMIN_EMAILS=you@example.com

# Inbound email (ray@inbound.checkray.app) — server-only, never NEXT_PUBLIC_.
# Gated Resend inbound: approved beta users or active/trialing paid users only.
# See docs/INBOUND_EMAIL_SETUP.md for Resend setup.
# RESEND_INBOUND_WEBHOOK_SECRET=whsec_...
# INBOUND_EMAIL_ADDRESS=ray@inbound.checkray.app

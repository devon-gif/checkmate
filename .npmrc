# pnpm 10 strictness tweaks for CheckRay.
#
# verify-deps-before-run=false
#   pnpm 10 runs an automatic `deps-status-check` before every script,
#   which surfaces ERR_PNPM_IGNORED_BUILDS as a fatal exit even when the
#   build script (e.g. @sentry/cli) was intentionally skipped. We have
#   already approved the relevant scripts via `pnpm.onlyBuiltDependencies`
#   in package.json; this just stops the pre-flight check from
#   second-guessing it on every script invocation.
#
# Vercel CI is unaffected — it calls `pnpm install --frozen-lockfile`
# directly (which exits 0) before the build script runs.
verify-deps-before-run=false
